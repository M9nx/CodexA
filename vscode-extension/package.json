{
  "name": "codexa",
  "displayName": "CodexA — Developer Intelligence",
  "description": "Semantic code search, symbol exploration, code quality analysis, AI Q&A, and agent tooling — powered by the CodexA intelligence engine.",
  "version": "0.2.0",
  "publisher": "M9nx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/M9nx/CodexA"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codexa.search",
    "onCommand:codexa.askCodexA",
    "onView:codexaSearchView",
    "onView:codexaSymbolsView",
    "onView:codexaQualityView",
    "onView:codexaToolsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexa.search",
        "title": "CodexA: Search Codebase",
        "icon": "$(search)"
      },
      {
        "command": "codexa.askCodexA",
        "title": "CodexA: Ask a Question",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codexa.callGraph",
        "title": "CodexA: Show Call Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "codexa.models",
        "title": "CodexA: List Models",
        "icon": "$(database)"
      },
      {
        "command": "codexa.quality",
        "title": "CodexA: Code Quality Analysis",
        "icon": "$(checklist)"
      },
      {
        "command": "codexa.explainSymbol",
        "title": "CodexA: Explain Symbol at Cursor",
        "icon": "$(lightbulb)"
      },
      {
        "command": "codexa.doctor",
        "title": "CodexA: Doctor (Health Check)",
        "icon": "$(heart)"
      },
      {
        "command": "codexa.index",
        "title": "CodexA: Re-Index Codebase",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexa",
          "title": "CodexA",
          "icon": "$(telescope)"
        }
      ]
    },
    "views": {
      "codexa": [
        {
          "type": "webview",
          "id": "codexaSearchView",
          "name": "Search"
        },
        {
          "type": "webview",
          "id": "codexaSymbolsView",
          "name": "Symbols & Graphs"
        },
        {
          "type": "webview",
          "id": "codexaQualityView",
          "name": "Quality"
        },
        {
          "type": "webview",
          "id": "codexaToolsView",
          "name": "Tools"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codexa.search",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5"
      },
      {
        "command": "codexa.explainSymbol",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "codexa.quality",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codexa.explainSymbol",
          "group": "codexa@1",
          "when": "editorTextFocus"
        },
        {
          "command": "codexa.callGraph",
          "group": "codexa@2",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "CodexA",
      "properties": {
        "codexa.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the codex binary. Leave empty to auto-detect from .venv or PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
